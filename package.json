  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.9",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^25.0.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "vite": "^6.2.5",
    "esbuild": "^0.25.0"
  },
  "resolutions": {
    "glob": "^10.4.5",
    "rimraf": "^5.0.10"
  }
}
