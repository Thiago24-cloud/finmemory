{
  "name": "finmemory",
  "version": "1.0.0",
  "private": true,
  "description": "FinMemory monorepo — consumidor + varejista + backend compartilhado",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "finmemory-agent"
  ],
  "scripts": {
    "dev": "npm run dev -w @finmemory/consumer",
    "dev:retailer": "npm run dev -w @finmemory/retailer",
    "build": "npm run build -w @finmemory/consumer",
    "build:retailer": "npm run build -w @finmemory/retailer",
    "build:all": "npm run build -w @finmemory/consumer && npm run build -w @finmemory/retailer",
    "postbuild": "node scripts/verify-build.mjs",
    "start": "npm run start -w @finmemory/consumer",
    "lint": "npm run lint -w @finmemory/consumer",
    "postinstall": "patch-package",
    "validate-env": "node scripts/validate-env.mjs",
    "stripe:activate-catalog": "node -r dotenv/config scripts/stripe-activate-catalog.mjs",
    "check-r2": "node scripts/check-r2-env.mjs",
    "verify-build": "node scripts/verify-build.mjs",
    "diagnose:sacolao": "node -r dotenv/config scripts/diagnose-sacolao-store-promos.mjs",
    "db:cleanup-promocoes-expired": "node -r dotenv/config scripts/run-promocoes-cleanup-expired.mjs",
    "agent": "node jobs/agent.js",
    "agent:finmemory": "node finmemory-agent/agent.js",
    "agent:supermercados": "node finmemory-agent/agent.js",
    "mapa-supervisor": "node scripts/mapa-supervisor.mjs",
    "promo:agent": "npm run start --prefix finmemory-agent",
    "promo:agent:dry": "npm run dry-run --prefix finmemory-agent",
    "promo:p1": "npm run prioridade1 --prefix finmemory-agent",
    "promo:p2": "npm run prioridade2 --prefix finmemory-agent",
    "promo:dia": "npm run dia --prefix finmemory-agent",
    "promo:dia:sp-estado": "node scripts/run-dia-estado-sp.mjs",
    "promo:regional": "npm run regional --prefix finmemory-agent",
    "promo:sonda": "npm run sonda --prefix finmemory-agent",
    "pluggy:register-webhook": "node -r dotenv/config scripts/register-pluggy-webhook.js",
    "pluggy:fix-webhook-secrets": "node -r dotenv/config scripts/fix-pluggy-webhook-secrets.js",
    "pluggy:resync-transacoes-institution": "node scripts/resync-pluggy-transacoes-institution.mjs",
    "deploy:cloud-run": "node scripts/deploy-cloud-run.mjs",
    "deploy:cloud-run:retailer": "node scripts/deploy-cloud-run-retailer.mjs",
    "set-cloud-run-env:retailer": "powershell -ExecutionPolicy Bypass -File scripts/set-cloud-run-env-retailer.ps1",
    "deploy:promo-agent-all": "node scripts/deploy-promo-agent-all.mjs",
    "promo:scheduler:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-promo-scheduler.ps1",
    "promo:scheduler:setup:sh": "bash scripts/setup-promo-scheduler.sh",
    "deploy:firebase-hosting": "npx firebase-tools deploy --only hosting",
    "promo:dia-env": "node scripts/sync-dia-store-urls.mjs",
    "curadoria:mambo-expand": "node scripts/mambo-expand-curadoria.mjs",
    "docker:build:promo-dia": "docker build -f finmemory-agent/Dockerfile -t finmemory-promo-dia:latest finmemory-agent",
    "docker:build:promo-agent-all": "docker build -f finmemory-agent/Dockerfile.all -t finmemory-promo-agent-all:latest finmemory-agent",
    "test": "vitest run",
    "auth:print-hash": "node scripts/print-scrypt-password-hash.mjs",
    "auth:check-hash-format": "node scripts/check-auth-local-password-format.mjs",
    "auth:test-credentials-http": "node scripts/test-nextauth-credentials.mjs",
    "promo:test-bot-fila-readiness": "node scripts/test-bot-fila-readiness.mjs",
    "promo:test-scraper": "node -r dotenv/config scripts/test-scraper.mjs",
    "promo:scraper:dia": "node -r dotenv/config scripts/run-scraper-dia-pending.mjs",
    "promo:scraper:dia:http": "node -r dotenv/config scripts/run-scraper-dia-pending.mjs --http",
    "promo:seed-scraper-stores": "node -r dotenv/config scripts/seed-scraper-stores.mjs",
    "promo:catalog-report": "node -r dotenv/config scripts/scraper-catalog-report.mjs",
    "promo:report-map-integrity": "node scripts/report-map-promo-integrity.mjs",
    "promo:test-google-cse": "node scripts/test-google-cse-curator.mjs",
    "catalog:enrich-images": "node -r dotenv/config scripts/enrich-product-images.mjs",
    "logo:strip-bg": "node scripts/strip-logo-corner-bg.mjs",
    "build:mobile": "vite build && npx cap sync android",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "ios:pod-install": "cd ios/App && pod install"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "jsdom": "^25.0.1",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "vite": "^6.2.5",
    "esbuild": "^0.25.0"
  },
  "resolutions": {
    "glob": "^10.4.5",
    "rimraf": "^5.0.10"
  }
}
