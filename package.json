    "@next/third-parties": "^15.5.14",
    "@radix-ui/react-dialog": "^1.1.14",
    "@supabase/supabase-js": "^2.45.4",
    "@swc/helpers": "^0.5.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.5.9",
    "googleapis": "^144.0.0",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.462.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.13",
    "openai": "^4.77.3",
    "playwright": "^1.58.2",
    "pluggy-js": "^0.19.3",
    "pluggy-sdk": "^0.83.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-pluggy-connect": "^2.12.0",
    "sonner": "^1.7.4",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^2.6.0"
