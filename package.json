{
  "name": "finmemory",
  "version": "1.0.0",
  "private": true,
  "description": "Automação financeira inteligente via e-mail",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "postinstall": "patch-package",
    "build": "next build",
    "postbuild": "node scripts/verify-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "validate-env": "node scripts/validate-env.mjs",
    "verify-build": "node scripts/verify-build.mjs",
    "agent": "node jobs/agent.js",
    "agent:finmemory": "node finmemory-agent/agent.js",
    "agent:supermercados": "node finmemory-agent/agent.js",
    "mapa-supervisor": "node scripts/mapa-supervisor.mjs",
    "promo:agent": "npm run start --prefix finmemory-agent",
    "promo:agent:dry": "npm run dry-run --prefix finmemory-agent",
    "promo:p1": "npm run prioridade1 --prefix finmemory-agent",
    "promo:p2": "npm run prioridade2 --prefix finmemory-agent",
    "promo:dia": "npm run dia --prefix finmemory-agent",
    "promo:dia:sp-estado": "node scripts/run-dia-estado-sp.mjs",
    "promo:regional": "npm run regional --prefix finmemory-agent",
    "promo:sonda": "npm run sonda --prefix finmemory-agent",
    "deploy:cloud-run": "node scripts/deploy-cloud-run.mjs",
    "deploy:promo-agent-all": "node scripts/deploy-promo-agent-all.mjs",
    "promo:scheduler:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-promo-scheduler.ps1",
    "promo:scheduler:setup:sh": "bash scripts/setup-promo-scheduler.sh",
    "deploy:firebase-hosting": "npx firebase-tools deploy --only hosting",
    "promo:dia-env": "node scripts/sync-dia-store-urls.mjs",
    "docker:build:promo-dia": "docker build -f finmemory-agent/Dockerfile -t finmemory-promo-dia:latest finmemory-agent",
    "docker:build:promo-agent-all": "docker build -f finmemory-agent/Dockerfile.all -t finmemory-promo-agent-all:latest finmemory-agent",
    "test": "vitest run",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "ios:pod-install": "cd ios/App && pod install"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
