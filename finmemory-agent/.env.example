# Copie para .env na mesma pasta do agent.js
# PowerShell: Copy-Item .env.example .env
# Depois: npm install && npm run setup

# Supabase — Settings → API → chave service_role (JWT, começa com eyJ)
# NÃO use a anon key. URL sem barra no final.
SUPABASE_URL=https://abcdefghijklm.supabase.co
SUPABASE_SERVICE_KEY=
# (alias: SUPABASE_SERVICE_ROLE_KEY)

# Agente Playwright (esta pasta) não usa OpenAI — só Playwright + Supabase
# OPENAI_API_KEY só é necessário se você usar o agent antigo baseado em GPT

# Geocoding (opcional — mesmo token Mapbox do app FinMemory)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# TTL em horas (padrão 72) e concorrência entre redes (1 = sequencial)
TTL_HOURS=72
CONCURRENCY=1
LOG_LEVEL=info

# Dia: uma loja ou várias (tabloides em page-data por URL). Opcional: coluna stores.promo_page_url
# Gere lista alinhada ao mapa: na raiz do monorepo → npm run promo:dia-env
# (lê public.stores + catálogo oficial DIA → .env.dia.generated e scripts/dia-stores-promo-page-url.sql)
# DIA_STORE_URL=https://www.dia.com.br/lojas/sp-sao-paulo-pinheiros-rua-teodoro-sampaio-1249-1251
# DIA_STORE_URLS=https://...,https://...   (ou uma URL por linha)
# DIA_MAX_STORE_PAGES=45
# DIA_MATCH_MAX_KM=1.2   (só no script sync-dia-store-urls.mjs)
#
# Replica ofertas nacionais (Atacadão, Carrefour, etc.) em cada pin da rede em public.stores:
# PROMO_FANOUT_MAX_STORES=80

# Rode no Supabase: supabase_schema.sql (SQL Editor)
