# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    FINMEMORY - VARIÁVEIS DE AMBIENTE                         ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║  Copie este arquivo para .env.local:                                         ║
# ║    cp .env.example .env.local                                                ║
# ║                                                                              ║
# ║  ⚠️  NUNCA commite .env.local no Git!                                        ║
# ║  ✅  Valide com: npm run validate-env                                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                         🗄️  SUPABASE (Banco de Dados)                        │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Onde encontrar:                                                             │
# │  https://supabase.com/dashboard → Seu Projeto → Settings → API               │
# └──────────────────────────────────────────────────────────────────────────────┘

# URL do projeto Supabase
# Tipo: Pública (pode ser exposta no cliente)
# Formato: https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (anon key)
# Tipo: Pública (pode ser exposta no cliente)
# Localização: Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua-chave-anon

# Chave de serviço (service role key)
# Tipo: 🔐 SECRETA - NUNCA exponha no cliente!
# Localização: Settings → API → Project API keys → service_role
# Uso: Apenas no servidor para operações administrativas
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua-chave-service

# JWT Secret (Settings → API → JWT Settings → JWT Secret)
# Usado para Realtime com sessão NextAuth (/api/supabase/realtime-token)
# Tipo: 🔐 SECRETA — servidor apenas
SUPABASE_JWT_SECRET=sua-jwt-secret-do-supabase


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      🔐  NEXTAUTH (Autenticação)                             │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  NextAuth.js gerencia a autenticação OAuth de forma segura                   │
# │  Documentação: https://next-auth.js.org                                      │
# └──────────────────────────────────────────────────────────────────────────────┘

# URL base do seu aplicativo
# Desenvolvimento: http://localhost:3000
# Produção Cloud Run (projeto exalted-entry-480904-s9): ver URL em
#   gcloud run services describe finmemory --region=southamerica-east1 --project=exalted-entry-480904-s9 --format="value(status.url)"
# Produção domínio próprio: https://www.finmemory.com.br
NEXTAUTH_URL=https://finmemory-836908221936.southamerica-east1.run.app

# Deploy Cloud Build: npm run deploy:cloud-run usa o projeto abaixo (não finmemory-667c3)
# GCLOUD_PROJECT=exalted-entry-480904-s9

# Chave secreta para criptografia de tokens
# Gere com: openssl rand -base64 32
# Tipo: 🔐 SECRETA
NEXTAUTH_SECRET=sua-chave-secreta-gerada-com-openssl

# Acesso ao app: por defeito aberto para qualquer e-mail cadastrado/verificado. Limitações = planos (checkout).
# FINMEMORY_PUBLIC_ACCESS=1 — explícito (modo público; redundante por defeito).
# Beta fechado: só estes e-mails (vírgula ou ponto e vírgula): FINMEMORY_PRIVATE_BETA_EMAILS=seu@email.com,outro@gmail.com
# Pré-lançamento (uma conta só): FINMEMORY_LOCKDOWN_SINGLE_USER=1 — ver FINMEMORY_DEFAULT_LOCKDOWN_EMAIL em lib/privateBetaAllowlist.js.

# Rollout gradual — só estes e-mails veem mapa, caça-preço, lista, missões e código de barras.
# FINMEMORY_PUBLIC_ACCESS=1 mantém login aberto; não libera estas features para todos.
# FINMEMORY_RESTRICTED_FEATURE_EMAILS=finmemory.oficial@gmail.com,nickzila2709@gmail.com
# NEXT_PUBLIC_RESTRICTED_FEATURE_EMAILS= (mesmo valor; embutido no bundle no deploy)

# Painel operacional /admin e POST /api/admin/* (sessão): só estes e-mails quando definido.
# Vários: vírgula ou ponto e vírgula. Se vazio, /admin usa o mesmo critério que o app (canAccess).
# FINMEMORY_ADMIN_EMAILS=thiagochimezie4@gmail.com

# Planos B2B (lojista): bloqueio de features por store_subscriptions.
# Padrão: ligado. STORE_FEATURE_GATES=0 desliga gates (útil em dev sem migration).
# STORE_FEATURE_GATES=1

# Critérios do relatório de validação do trial (JSON opcional).
# FINMEMORY_TRIAL_VALIDATION_CRITERIA={"min_customers":30,"min_direct_orders":10,"min_recurring_customers":3,"require_willing_to_pay":true,"marketplace_fee_rate":0.2}

# Opcional: URL base explícita usada em links de segurança (fallback para NEXTAUTH_URL)
# APP_BASE_URL=https://finmemory.com.br
# Opcional: remetente para emails de verificação/reset
# AUTH_EMAIL_FROM=FinMemory <no-reply@finmemory.com.br>
# Obrigatório no Cloud Run retailer para e-mail de cadastro com link + senha:
# RESEND_API_KEY=re_xxx
# Opcional: emissor mostrado no app autenticador TOTP
# AUTH_TOTP_ISSUER=FinMemory
# Opcional: provedor de email (Resend) para envio real de verificação/reset
# RESEND_API_KEY=re_xxx


# 🔐 Login social (NextAuth) — Google e Facebook
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# FACEBOOK_CLIENT_ID=xxx
# FACEBOOK_CLIENT_SECRET=xxx
# Callback: {NEXTAUTH_URL}/api/auth/callback/google (e /facebook)
# Ver docs/CHECKLIST-REDIRECIONAMENTO-AUTH.md


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              💳  STRIPE (Plus / Pro / Família + webhook)                     │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Webhook (Stripe → Desenvolvedores → Webhooks):                             │
# │    https://finmemory.com.br/api/webhook                                     │
# │  Eventos usados: checkout.session.completed, customer.subscription.*,       │
# │    invoice.payment_failed                                                    │
# │  Price IDs: Dashboard Stripe → Produtos → preço recorrente → price_...     │
# │  Preferir STRIPE_*_PRICE_ID no servidor; NEXT_PUBLIC_* é fallback opcional. │
# └──────────────────────────────────────────────────────────────────────────────┘

# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_APP_URL=https://finmemory.com.br

# App lojista (subdomínio parceiros) — consumer usa para links/push; retailer usa como base URL
# NEXT_PUBLIC_RETAILER_APP_URL=https://parceiros.finmemory.com.br

# Price IDs (exemplo produção — substitua pelos seus no Stripe)
# STRIPE_PLUS_PRICE_ID=price_1TNsF9IploEtOf6afIb4EiHI
# STRIPE_PRO_PRICE_ID=price_1TSMW3IploEtOf6az2g4IMMa
# STRIPE_FAMILIA_PRICE_ID=price_1TNsHtIploEtOf6a0C9eeQTS
# STRIPE_ENTERPRISE_PRICE_ID=price_...
# Opcional (mesmos IDs, se quiser duplicar no cliente):
# NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID=price_1TNsF9IploEtOf6afIb4EiHI
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1TSMW3IploEtOf6az2g4IMMa
# NEXT_PUBLIC_STRIPE_FAMILIA_PRICE_ID=price_1TNsHtIploEtOf6a0C9eeQTS
#
# Stripe Connect — pedidos Parceiros (destination charge para a loja)
# STRIPE_CONNECT_PLATFORM_FEE_PERCENT=5
# STRIPE_CONNECT_ORDERS_DISABLED=1
# Webhook /api/webhook: eventos checkout.session.* (pedido) e account.updated (Connect)


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              💳  CIELO (gateway oficial FinMemory — eCommerce REST)          │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Credenciais: portal lojista cielo.com.br → E-commerce → API E-commerce      │
# │               → Credenciais (MerchantId + MerchantKey)                       │
# │  Docs: https://docs.cielo.com.br/ecommerce-cielo/                          │
# │  API create: POST /api/payments/cielo/create                                 │
# │  API status: GET  /api/payments/cielo/status/[paymentId]                   │
# └──────────────────────────────────────────────────────────────────────────────┘

# CIELO_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CIELO_MERCHANT_KEY=0123456789012345678901234567890123456789
# CIELO_ENV=production
# Opcional — override de URLs (padrão conforme CIELO_ENV):
# CIELO_TRANSACTION_URL=https://apisandbox.cieloecommerce.cielo.com.br
# CIELO_QUERY_URL=https://apiquerysandbox.cieloecommerce.cielo.com.br


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              💳  e-Rede / Itaú Rede (sandbox + produção)                     │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Credenciais: Portal do Desenvolvedor → projeto → PV + Token                 │
# │    https://developer.userede.com.br/login                                    │
# │  Docs / coleção Postman: https://developer.userede.com.br/e-rede             │
# │  Sandbox: https://sandbox-erede.useredecloud.com.br                          │
# │  APIs painel lojista:                                                        │
# │    POST /api/parceiros/painel/payments/erede/authorize                       │
# │    PUT  /api/parceiros/painel/payments/erede/capture                         │
# │    GET  /api/parceiros/painel/payments/erede/query?tid=...                     │
# │    POST /api/parceiros/painel/payments/erede/cancel                          │
# │    GET  /api/parceiros/painel/payments/erede/status                          │
# └──────────────────────────────────────────────────────────────────────────────┘

# EREDE_PV=<informe-pv>
# EREDE_TOKEN=<informe-token>
# EREDE_ENV=sandbox
# Opcional:
# EREDE_BASE_URL=https://sandbox-erede.useredecloud.com.br
# EREDE_API_VERSION=v1


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              ☁️  CLOUDFLARE R2 (recibos / comprovantes — OCR)                 │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Dashboard R2 → bucket → Settings → Public access / custom domain           │
# │  O nome do bucket é o slug técnico (sem espaços), não o rótulo na UI.         │
# │  Se as variáveis abaixo estiverem definidas, POST /api/ocr/process-receipt   │
# │  grava em R2; caso contrário mantém Supabase Storage (bucket receipts).       │
# └──────────────────────────────────────────────────────────────────────────────┘
# CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=finmemory-storage
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://finmemory.com.br
# Aliases aceitos: CLOUDFLARE_R2_BUCKET_NAME, CLOUDFLARE_R2_PUBLIC_URL
# Em Cloud Run (K_SERVICE) o R2 é obrigatório — o servidor não sobe sem estas variáveis.

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              🔥  Reengajamento / streak / push (OneSignal)                    │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  CRON_SECRET — protege POST /api/cron/reengagement-inactive                 │
# │  ONESIGNAL_APP_ID + ONESIGNAL_REST_API_KEY — push (opcional; sem eles só log) │
# │  GitHub Actions: secrets APP_URL (ou FINMEMORY_APP_URL) + CRON_SECRET         │
# └──────────────────────────────────────────────────────────────────────────────┘
# CRON_SECRET=
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# Push oferta relâmpago (parceiros → consumidores no raio):
# MERCHANT_NEARBY_PUSH_RADIUS_KM=3
# MERCHANT_NEARBY_PUSH_COOLDOWN_HOURS=24
# MERCHANT_NEARBY_PUSH_LOCATION_MAX_AGE_HOURS=168
# FINMEMORY_REQUIRE_R2=1 força a mesma regra localmente (next start).


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      🤖  OPENAI (Inteligência Artificial)                    │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Onde encontrar:                                                             │
# │  https://platform.openai.com/api-keys                                        │
# │                                                                              │
# │  💡 Dica: A chave só aparece uma vez ao criar! Salve imediatamente.          │
# │  💰 Custo: ~$0.01-0.05 por nota fiscal processada                            │
# │  📊 Monitore: https://platform.openai.com/usage                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# API Key da OpenAI
# Tipo: 🔐 SECRETA
# Formato: sk-proj-[HASH] ou sk-[HASH]
OPENAI_API_KEY=sk-proj-sua-chave-openai


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      📈  GOOGLE ANALYTICS (GA4)                              │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  O gtag só carrega em hosts listados (evita spam de localhost/preview).    │
# │  Opcional: sobrescreva o ID ou a lista de domínios (separados por vírgula).  │
# └──────────────────────────────────────────────────────────────────────────────┘

# NEXT_PUBLIC_GA_ID=G-K783HNBGE8
# NEXT_PUBLIC_GA_ALLOWED_HOSTS=finmemory.com.br,www.finmemory.com.br,finmemory-836908221936.southamerica-east1.run.app


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      🗺️  MAPBOX (Mapa de Preços)                             │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Onde encontrar: https://account.mapbox.com/access-tokens/                   │
# │  Token público (pk.ey...) - pode ser exposto no cliente                      │
# └──────────────────────────────────────────────────────────────────────────────┘

# Mapbox Access Token (público)
# Tipo: Pública (usada no browser para o mapa)
# Formato: pk.eyJ1Ijoi...
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijoic2V1LXVzdWFyaW8iLCJhIjoiY20uLi59.sua-chave-mapbox


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              🛒  COSMOS BLUESOFT (fallback nome por GTIN — só servidor)       │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Quando o Open Food Facts não tem nome, o app tenta api.cosmos.bluesoft.com.br│
# │  Plano gratuito com limite de requisições — não expor no cliente.             │
# │  Cloud Run: gcloud run services update finmemory --update-env-vars=...       │
# └──────────────────────────────────────────────────────────────────────────────┘

# COSMOS_API_TOKEN=              # só no Cloud Run do app consumidor (finmemory)
# COSMOS_USE_RETAILER_API=1      # opcional: GET /retailers/products?query= (base do varejista)
# COSMOS_LOOKUP_SECRET=          # opcional: protege GET /api/catalog/cosmos/lookup (retailer envia X-Finmemory-Cosmos-Secret)
# NEXT_PUBLIC_CONSUMER_APP_URL=  # no retailer: base do consumer para proxy Cosmos + iframe do mapa


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              📍 GOOGLE PLACES (script scripts/populate-stores.mjs)            │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Onde encontrar: Google Cloud Console → APIs & Services → Credentials       │
# │  Ative a API "Places API (New)" e crie uma chave de API                      │
# └──────────────────────────────────────────────────────────────────────────────┘

# Chave da API Google Places (para popular tabela stores)
# Tipo: 🔐 SECRETA - use apenas em scripts no servidor
GOOGLE_PLACES_API_KEY=sua-chave-google-places


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │              📦 Catálogo (products + product-images / Storage)              │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  POST /api/catalog/register-product-image — liga ficheiro no bucket         │
# │  `product-images` a um produto (GTIN + nome ou productId).                  │
# │  Se não definir, reutiliza DIA_IMPORT_SECRET (X-Cron-Secret ou ?secret=).   │
# └──────────────────────────────────────────────────────────────────────────────┘
# CATALOG_REGISTER_SECRET=
# CATALOG_ENRICH_SECRET=              # POST /api/catalog/enrich-product-images e process-image-sync (Cosmos→R2)
# npm run catalog:enrich-images       # script: scripts/enrich-product-images.mjs
# POST /api/promotions/extract-flyer-vision — extrai produtos de imagem de encarte (OpenAI Vision → promocoes_supermercados + promotions).
# Autenticação: utilizador com sessão NextAuth (ex.: /admin/quick-add) OU X-Cron-Secret / ?secret= (mesmos fallbacks do catálogo / DIA).
# Se não definir segredo no env, só sessão (ou rede aberta — evite em produção sem outra camada).
# ENCARTE_EXTRACT_SECRET=
# Worker POST /api/encarte/extract: visão OpenAI (padrão) ou Gemini.
# ENCARTE_VISION_PROVIDER=openai
# ENCARTE_VISION_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_ENCARTE_MODEL=gemini-2.0-flash
# GEMINI_ENCARTE_MAX_OUTPUT_TOKENS=8192
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_VISION_MAX_TOKENS=4096
# extractPromoFromEncarte → enfileira em public.encarte_queue; worker POST /api/encarte/extract (modelo GPT).
# CRON_SECRET=...                    # protege POST /api/encarte/extract e GET /api/encarte/process-queue (header x-cron-secret)
# ENCARTE_QUEUE_BATCH=5
# extractPromoFromEncarte (lib/extractPromoFromEncarte.js) → tabela public.promotions; modelo padrão gpt-4o:
# EXTRACT_PROMO_VISION_MODEL=gpt-4o
# Opcional (fallback de imagens pelo Google Custom Search API):
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      🗺️  Mapa de preços (TTL + viewport grande)               │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  MAP_DEFAULT_TTL_HOURS — pontos comuns (padrão 24)                           │
# │  MAP_PROMO_TTL_HOURS — categoria com "promo" (ex.: import DIA; padrão 168 = 7d) │
# │  Vista estado SP (bbox largo): limites maiores em GET /api/map/points e    │
# │  /api/map/stores — ajuste se precisar (defaults já sobem para ~estado).      │
# └──────────────────────────────────────────────────────────────────────────────┘
# MAP_DEFAULT_TTL_HOURS=24
# MAP_PROMO_TTL_HOURS=168
# MAP_POINTS_BBOX_ROW_LIMIT=320
# MAP_POINTS_BBOX_OUT_CAP=320
# MAP_POINTS_BBOX_ROW_LIMIT_LARGE=900
# MAP_POINTS_BBOX_OUT_CAP_LARGE=1400
# MAP_STORES_BBOX_LIMIT=600
# MAP_STORES_BBOX_LIMIT_LARGE=1800
# MAP_STORE_OFFERS_RADIUS_KM — raio (km) oferta↔pin quando não há match de slug de rede (padrão 1.25)
# MAP_STORE_OFFERS_RADIUS_KM=1.25
# MAP_STORE_OFFERS_CHAIN_SLUG_RADIUS_KM — quando slug (ex. saojorge) bate com o nome da loja, permite coords mais afastadas (curadoria; padrão 2.5)
# MAP_STORE_OFFERS_CHAIN_SLUG_RADIUS_KM=2.5
# MAP_STORE_OFFER_PREVIEW_LIMIT — máx. itens em offer_preview por loja no GET /api/map/stores (popup do pin; padrão 80, min 16, max 250). offer_count continua com o total.
# MAP_STORE_OFFER_PREVIEW_LIMIT=80
# Por padrão, o mapa NÃO consome public.promocoes_supermercados (força fluxo via bot_fila -> aprovação -> price_points).
# Para reativar temporariamente o feed legado do agente no mapa:
# MAP_ALLOW_AGENT_PROMOTIONS=1
# POST /api/map/quick-add-stream + página /mapa-quick-add — curadoria com SSE (progresso por etapa/produto).
# Sessão NextAuth já basta; para scripts sem login: header x-map-quick-add-secret
# MAP_QUICK_ADD_SECRET=
# user_id (UUID) em public.users para inserções via secret (ex. conta técnica curadoria)
# MAP_QUICK_ADD_BOT_USER_ID=
# Scrapers/cron DIA — UUID em public.users (conta técnica, não e-mail de admin):
#   npm run promo:ensure-bot-owner -- --write-env
# BOT_PROMO_OWNER_USER_ID=
# DIA_BOT_USER_ID=
# Quick Add: ao inserir price_points, resolve miniatura (cache Supabase → Open Food Facts → Google CSE) e grava image_url + map_product_image_cache.
# Listas grandes: miniaturas em paralelo + insert em lote (admin/quick-add e map/quick-add-stream).
# QUICK_ADD_THUMB_CONCURRENCY=6        # 1–16, pedidos externos em paralelo por pedido
# QUICK_ADD_INSERT_CHUNK_SIZE=80      # linhas por INSERT ao Supabase (5–500)
# QUICK_ADD_RESOLVE_IMAGE=0 para desligar. QUICK_ADD_GOOGLE_CSE=1 força CSE no Quick Add (senão usa só MAP_POINTS_GOOGLE_CSE_FALLBACK=1).
# Miniaturas do mapa: busca contextual (loja + produto + comida), filtro de URLs de suplementos; opcional validação por visão:
# MAP_PRODUCT_IMAGE_VISION_VALIDATE=1   # exige OPENAI_API_KEY; rejeita imagens claramente fora do contexto (custo por imagem)
# MAP_PRODUCT_IMAGE_VISION_MODEL=gpt-4o-mini
# Regras keyword→categoria/URL: map_thumbnail_match_rules (coluna opcional image_url) + /admin/map-thumbnail-rules
# MAP_THUMBNAIL_STATIC_RULES=0   # só BD (após migrares e preencheres regras)
# MAP_THUMBNAIL_RULES_CACHE_MS=45000   # cache em memória das regras por instância Node
# QUICK_ADD_RESOLVE_IMAGE=
# QUICK_ADD_GOOGLE_CSE=


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │         🤖 finmemory-agent (promoções DIA e outras redes — Playwright)        │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Correr na raiz: npm run promo:dia  →  --only=dia                            │
# │  Capital SP: ~121 lojas (slug sp-sao-paulo-*); DIA_MAX_STORE_PAGES=250       │
# │  cobre num job. Estado SP (todas as lojas do JSON regional):                 │
# │    npm run promo:dia:sp-estado  (define DIA_REGION_INCLUDE_ALL_NODES=1)    │
# │  Cloud Run Job: task timeout ≥ 3600s (ex.: 5400s); estado pode precisar mais.│
# │  Ver também: docs/DIA-MAPA-IMPORTAR-OUTRA-LOJA.md                           │
# └──────────────────────────────────────────────────────────────────────────────┘
# DIA_MAX_STORE_PAGES=250
# DIA_REGION_PAGE_PATHS=lojas-sp-capital
# DIA_REGION_INCLUDE_ALL_NODES=0
# DIA_SKIP_REGION_LIST=0
# CONCURRENCY=1


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                      🏦  PLUGGY (Open Finance)                                │
# ├──────────────────────────────────────────────────────────────────────────────┤
# │  Dashboard: https://dashboard.pluggy.ai — credenciais de API (Client ID/Secret) │
# │  Webhook produção: https://finmemory.com.br/api/pluggy/webhook (GET confirma; POST recebe eventos) │
# │  Webhooks criados só no dashboard NÃO enviam headers custom — com PLUGGY_WEBHOOK_SECRET │
# │  no Cloud Run o POST devolve 401. Use a API Pluggy (Create Webhook) com "headers": │
# │  { "Authorization": "Bearer <mesmo valor que PLUGGY_WEBHOOK_SECRET>" } ou npm run pluggy:register-webhook. │
# │  Eventos: item/*, transactions/* ou "all". Ver pages/api/pluggy/webhook.js.   │
# └──────────────────────────────────────────────────────────────────────────────┘
#
# Modelo para .env.local / Cloud Run (substituir pelos valores reais):
#
# PLUGGY_CLIENT_ID=seu_client_id_aqui
# PLUGGY_CLIENT_SECRET=seu_client_secret_aqui
# PLUGGY_WEBHOOK_SECRET=o_segredo_que_geraste
# PLUGGY_WEBHOOK_URL=https://finmemory.com.br/api/pluggy/webhook
#
# O segredo do webhook deve ser o mesmo no header (npm run pluggy:register-webhook) e em PLUGGY_WEBHOOK_SECRET.
# Sem PLUGGY_WEBHOOK_URL: usa-se NEXT_PUBLIC_APP_URL ou NEXTAUTH_URL + /api/pluggy/webhook no script.
#
# PLUGGY_WEBHOOK_EVENT=all
# npm run pluggy:register-webhook
# Se já existirem webhooks na mesma URL mas sem header (401): npm run pluggy:fix-webhook-secrets
# Padrão (omitir variável): widget com bancos reais (produção Pluggy aprovada).
# Só Pluggy Bank sandbox (trial/dev): PLUGGY_WIDGET_SANDBOX_CONNECTOR_ONLY=true
# (também em Cloud Run.) O cliente NÃO lê esta variável — só o servidor em pages/api/pluggy/connect-token.js;
# a API devolve useSandboxConnectorOnly para o widget (components/ConnectBank.js).
# PLUGGY_WIDGET_SANDBOX_CONNECTOR_ONLY=true
# Opcional: ID numérico do conector Pluggy Bank se a resolução automática falhar (dashboard Pluggy / GET /connectors?sandbox=true)
# PLUGGY_SANDBOX_CONNECTOR_ID=


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            📋  REFERÊNCIA RÁPIDA                             ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║                                                                              ║
# ║  VARIÁVEIS PÚBLICAS (NEXT_PUBLIC_*):                                         ║
# ║  ├─ NEXT_PUBLIC_SUPABASE_URL      → Expostas no navegador                    ║
# ║  ├─ NEXT_PUBLIC_SUPABASE_ANON_KEY → Seguras para o cliente                   ║
# ║  ├─ NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN → Mapa de preços (Mapbox)                ║
# ║  ├─ NEXT_PUBLIC_GA_ID (opcional)    → Measurement ID GA4                     ║
# ║  └─ NEXT_PUBLIC_GA_ALLOWED_HOSTS    → Domínios que podem enviar eventos GA   ║
# ║                                                                              ║
# ║  VARIÁVEIS SECRETAS (servidor apenas):                                       ║
# ║  ├─ SUPABASE_SERVICE_ROLE_KEY     → Acesso admin ao banco                    ║
# ║  ├─ NEXTAUTH_URL                  → URL base do app                          ║
# ║  ├─ NEXTAUTH_SECRET               → Criptografia de sessão                   ║
# ║  ├─ RESEND_API_KEY               → Envio de email de segurança               ║
# ║  ├─ GOOGLE_PLACES_API_KEY        → Script populate-stores.mjs               ║
# ║  └─ OPENAI_API_KEY                → Processamento de NFs                     ║
# ║                                                                              ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║                                                                              ║
# ║  📖 DOCUMENTAÇÃO:                                                            ║
# ║  ├─ docs/DEPLOY-GOOGLE-CLOUD-RUN.md → Deploy produção (Cloud Run)            ║
# ║  ├─ CHECKLIST-DEPLOY.md  → Lista de verificação (Cloud Run)                  ║
# ║  ├─ SETUP-ENV.md         → Configuração passo a passo                      ║
# ║  └─ CONFIGURAR-VERCEL.md → Referência de nomes de variáveis (legado)       ║
# ║                                                                              ║
